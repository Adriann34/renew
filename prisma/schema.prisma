// This is a starter schema — we'll expand this together in the next step.
// Run `npx prisma migrate dev` after setting DATABASE_URL to your Supabase
// connection string (use the "connection pooling" URL for serverless).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Grade {
  A
  B
  C
}

enum Category {
  GPU
  CPU
  MOTHERBOARD
  RAM
  STORAGE
  PSU
  OTHER
}

enum PhotoKind {
  CONDITION
  BURN_IN
  BENCHMARK
  BOOT
}

enum ListingStatus {
  ACTIVE
  SOLD
}

model User {
  id                  String         @id // matches Supabase auth.users.id — set explicitly, not generated here
  email               String         @unique
  name                String?
  phone               String?
  location            String?
  avatarUrl           String?
  // ISO 4217 code of the currency this user prefers to SEE prices in (display only —
  // never changes what a listing is actually priced in). Null = fall back to
  // auto-detect (Accept-Language) then USD. See lib/currency.ts.
  preferredCurrency   String?
  createdAt           DateTime       @default(now())
  listings            Listing[]
  saved               SavedListing[]
  buyerConversations  Conversation[] @relation("BuyerConversations")
  sellerConversations Conversation[] @relation("SellerConversations")
  messages            Message[]
}

model Listing {
  id              String         @id @default(uuid())
  title           String
  category        Category
  // The seller's real asking price, in WHOLE major units of `currency` (e.g. 12000
  // means ₱12,000 when currency = "PHP", $450 when "USD"). This is the source of
  // truth — buyers may see an approximate conversion, but this number is what the
  // seller wants. Existing rows predate multi-currency and are all USD (see migration default).
  price           Int
  currency        String         @default("USD") // ISO 4217; validated against lib/currency.ts
  grade           Grade
  spec            String
  location        String
  description     String         @default("")
  benchmarkScore  Int
  benchmarkLabel  String
  wattageDraw     Int
  bootVerified    Boolean        @default(false)
  // AI photo-verification (Gemini vision): does the seller's proof match their claims?
  // aiVerdict holds the full structured AiVerificationResult; aiVerified is the
  // denormalized "overall verified" flag for cheap badge/filter checks. Both are
  // cleared/refreshed whenever the listing's claims or photos change (see edit action).
  aiVerified      Boolean        @default(false)
  aiVerdict       Json?
  aiCheckedAt     DateTime?
  status          ListingStatus  @default(ACTIVE)
  sellerId        String
  seller          User           @relation(fields: [sellerId], references: [id])
  photos          ListingPhoto[]
  savedBy         SavedListing[]
  conversations   Conversation[]
  createdAt       DateTime       @default(now())
}

model SavedListing {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model ListingPhoto {
  id        String    @id @default(uuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  kind      PhotoKind
  url       String
  createdAt DateTime  @default(now())
}

// RLS is enabled on Conversation + Message only (see the chat migration for
// the policies) so Realtime subscriptions can only stream rows the signed-in
// user is actually part of. Every other table has no RLS and relies entirely
// on server-side auth checks in Server Actions instead.
model Conversation {
  id               String    @id @default(uuid())
  listingId        String
  listing          Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId          String
  buyer            User      @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId         String
  seller           User      @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages         Message[]
  buyerLastReadAt  DateTime? // per-user read markers — cheaper than per-message readAt
  sellerLastReadAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt // auto-bumped on every write (incl. mark-as-read); NOT the inbox sort key — getConversationsForUser sorts by last message time

  @@unique([listingId, buyerId]) // one thread per buyer per listing
  @@index([buyerId])
  @@index([sellerId])
}

// Fixed-window rate-limit + usage-cap counters. One row per (key, windowStart):
// `key` identifies the bucket ("ai:user:<id>", "ai:ip:<ip>", "ai:global",
// "upload:user:<id>"), `windowStart` is the floored start of the current window,
// and `count` is atomically incremented via upsert. Rows for elapsed windows are
// dead and can be reaped (see @@index) — nothing reads them once the window rolls.
// This is the ONLY cost/abuse control in the app: without it a single free signup
// could spam Gemini + sharp without limit. Cheap paths fail open, AI paths fail
// closed (see lib/rateLimit.ts).
model RateLimit {
  key         String
  windowStart DateTime
  count       Int      @default(0)

  @@id([key, windowStart])
  @@index([windowStart])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String       @default("") // may be empty when attachment-only
  attachmentUrl  String? // storage path in the private chat-attachments bucket, if any (served via /api/chat-attachment/[id])
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}
