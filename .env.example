# Supabase Postgres — use the pooled connection string for DATABASE_URL
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Supabase project (client-side, safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Server-only — Settings > API > secret key. NEVER expose to the client
# (no NEXT_PUBLIC_ prefix). Used for admin.deleteUser (account deletion) and
# to bypass bucket RLS for avatar/chat-attachment uploads (paths outside the
# listing-photo RLS scope).
SUPABASE_SECRET_KEY="sb_secret_..."
