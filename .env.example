# Supabase Postgres — copy both from the dashboard's "Connect" button (Prisma tab).
# DATABASE_URL: transaction-mode pooler (6543) for app queries.
# DIRECT_URL:   session-mode pooler (5432), used by `prisma migrate`.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase project (client-side, safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Server-only — Settings > API > secret key. NEVER expose to the client
# (no NEXT_PUBLIC_ prefix). Used for admin.deleteUser (account deletion) and
# to bypass bucket RLS for avatar/chat-attachment uploads.
SUPABASE_SECRET_KEY="sb_secret_..."

# Server-only — Google AI Studio (Gemini) API key for AI photo-verification of
# listings (lib/aiVerify.ts). Get one free (no card) at https://aistudio.google.com/apikey.
# Optional: if unset, listing creation/editing still works — the AI verdict is
# simply skipped. Free-tier note: listing photos are already public, so free-tier
# data-usage terms are not a concern here (do NOT reuse this for private content).
GEMINI_API_KEY="..."
